# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Binary files
*.mp4 binary
*.webm binary
*.webp binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary

# Windows specific
* text=auto eol=crlf